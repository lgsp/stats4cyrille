\section{Arbres de régression et de classification}

\subsection{Contexte}
Les arbres font partie des méthodes supervisées. Leur but est d'expliquer et/ou prédire une variable réponse $Y$ à partir d'un ensemble de variables explicatives $X = (X_1, \ldots, X_p)$.

\subsection{Généralités}

\subsubsection{Principe}
Les arbres sont des méthodes de \textbf{segmentation}. Le principe est de partitionner l'espace des variables explicatives en $R$ régions distinctes $\mathcal{R}_1, \ldots, \mathcal{R}_R$. La prédiction pour une observation $x$ est alors:
\[
f(x) = \sum_{r=1}^{R} c_r \mathbb{I}(x \in \mathcal{R}_r)
\]
où $c_r$ est une constante (la moyenne des $y_i$ dans la région $r$ pour la régression, ou la classe majoritaire pour la classification).

\subsubsection{Représentations graphiques}
Un arbre peut être représenté de deux façons:
\begin{enumerate}
  \item Un arbre de décision avec des noeuds (divisions) et des feuilles (régions terminales)
  \item Un partitionnement de l'espace des entrées en régions rectangulaires
\end{enumerate}

\subsection{Construction d'un arbre}

\subsubsection{Arbres de régression}
\textbf{Modèle.} Pour une partition donnée, on minimise l'erreur quadratique:
\[
\mathcal{C}_{MC} = \sum_{i=1}^{n} (y_i - f(x_i))^2
\]

\textbf{Recherche d'une partition optimale.} On procède par divisions dyadiques récursives. Pour une région, on cherche la variable $j$ et le seuil $s$ qui minimisent:
\[
\min_{s,j} \left[ \min_{c_1} \sum_{x_i \in \mathcal{R}_1(j,s)} (y_i - c_1)^2 + \min_{c_2} \sum_{x_i \in \mathcal{R}_2(j,s)} (y_i - c_2)^2 \right]
\]
où $\mathcal{R}_1(j,s) = \{X \mid X_j \leq s\}$ et $\mathcal{R}_2(j,s) = \{X \mid X_j > s\}$.

\subsubsection*{Application numérique — Recherche du meilleur seuil}
Six clients avec leur âge et leur score de crédit~:

\begin{center}
\begin{tabular}{ccc}
\toprule
Client & Âge & Score \\
\midrule
1 & 23 & 62 \\
2 & 35 & 75 \\
3 & 45 & 85 \\
4 & 28 & 65 \\
5 & 50 & 90 \\
6 & 32 & 72 \\
\bottomrule
\end{tabular}
\end{center}

\noindent\textbf{Scission à 30~ans~:} $\mathcal{R}_1=\{23,28\}$, $\hat{c}_1=63.5$ \quad
$\mathcal{R}_2=\{35,45,50,32\}$, $\hat{c}_2=80.5$
\begin{align*}
MSE &= (62-63.5)^2 + (65-63.5)^2 + (75-80.5)^2 + (85-80.5)^2 + (90-80.5)^2 + (72-80.5)^2 \\
MSE &= 4.5+213 \\
MSE &= 217.5
\end{align*}

\noindent\textbf{Scission à 40~ans~:} $\mathcal{R}_1=\{23,35,28,32\}$, $\hat{c}_1=68.5$ \quad
$\mathcal{R}_2=\{45,50\}$, $\hat{c}_2=87.5$
\begin{align*}
  MSE &= (62-68.5)^2 + (75-68.5)^2 + (65-68.5)^2 + (72-68.5)^2 + (85-87.5)^2 + (90-87.5)^2 \\
  MSE &= 109+12.5 \\
  MSE &= 121.5
\end{align*}

Le seuil 40~ans minimise MSE (121.5 $<$ 217.5). On retient cette division.

\medskip
\noindent\textbf{Code Python~:}
\begin{lstlisting}[language=Python]
import numpy as np
age = np.array([23, 35, 45, 28, 50, 32])
score = np.array([62, 75, 85, 65, 90, 72])
for s in [30, 40]:
    c1, c2 = score[age <= s].mean(), score[age > s].mean()
    mse = ((score[age <= s] - c1)**2).sum() + ((score[age > s] - c2)**2).sum()
    print(f"Seuil {s}: MSE = {mse:.2f}")
\end{lstlisting}

\noindent\textbf{Code R~:}
\begin{lstlisting}[]
age <- c(23, 35, 45, 28, 50, 32)
score <- c(62, 75, 85, 65, 90, 72)
for (s in c(30, 40)) {
  c1 <- mean(score[age <= s]); c2 <- mean(score[age > s])
  mse <- sum((score[age <= s] - c1)^2) + sum((score[age > s] - c2)^2)
  cat(sprintf("Seuil %d: MSE = %.2f\n", s, mse))
}
\end{lstlisting}

\textbf{Élagage (pruning).} Un arbre trop profond souffre de sur-apprentissage. On utilise le \textbf{critère coût-complexité}:
\[
C_\alpha(A) = \underbrace{\sum_{r=1}^{|A|} \sum_{x_i \in \mathcal{R}_r} (y_i - \hat{c}_r)^2}_{\text{erreur d'ajustement}} + \alpha |A|
\]
où $|A|$ est le nombre de feuilles et $\alpha \geq 0$ un paramètre de pénalité.

\subsubsection*{Application numérique — Élagage}
Soit un arbre $A$ avec $|A|=6$ feuilles et une erreur de 200.
Un sous-arbre élagué $A'$ a $|A'|=3$ feuilles et une erreur de 260.

\[
\begin{array}{c|c|c}
\alpha & C_\alpha(A)=200+6\alpha & C_\alpha(A')=260+3\alpha \\ \midrule
15 & 290 & \textbf{305} \\
30 & \textbf{380} & 350 \\
\end{array}
\]

Pour $\alpha=15$, $A$ est préféré (290 $<$ 305).
Pour $\alpha=30$, $A'$ est préféré (350 $<$ 380).
Plus $\alpha$ est grand, plus on pénalise la complexité.

\medskip
\noindent\textbf{Code Python~:}
\begin{lstlisting}[language=Python]
for alpha in [15, 30]:
    c_a  = 200 + alpha * 6
    c_a2 = 260 + alpha * 3
    best = "A" if c_a < c_a2 else "A'"
    print(f"alpha={alpha}: C(A)={c_a}, C(A')={c_a2} -> {best}")
\end{lstlisting}

\noindent\textbf{Code R~:}
\begin{lstlisting}[]
for (alpha in c(15, 30)) {
  c_a  <- 200 + alpha * 6
  c_a2 <- 260 + alpha * 3
  best <- ifelse(c_a < c_a2, "A", "A'")
  cat(sprintf("alpha=%d: C(A)=%d, C(A')=%d -> %s\n", alpha, c_a, c_a2, best))
}
\end{lstlisting}

L'algorithme CART construit d'abord l'arbre maximal, puis l'élague en générant une séquence de sous-arbres emboîtés. Le meilleur sous-arbre est choisi par validation croisée ou sur un échantillon de validation.

\subsubsection{Arbre de classification}
Quand $Y$ est qualitative à $M$ modalités, on utilise des \textbf{critères d'impureté}:

\begin{itemize}
  \item \textbf{Erreur de mauvais classement:} $\frac{1}{n_r} \sum_{x_i \in \mathcal{R}_r} \mathbb{I}(y_i \neq \hat{y}_i)$
  \item \textbf{Indice de Gini:} $\sum_{m \neq m'} \hat{p}_{rm} \hat{p}_{rm'} = \sum_{m=1}^{M} \hat{p}_{rm} (1 - \hat{p}_{rm})$
  \item \textbf{Déviance (entropie):} $-\sum_{m=1}^{M} \hat{p}_{rm} \log \hat{p}_{rm}$
\end{itemize}
où $\hat{p}_{rm} = \frac{1}{n_r} \sum_{x_i \in \mathcal{R}_r} \mathbb{I}(y_i = m)$.

\subsubsection*{Application numérique — Critères d'impureté}
Dans une région contenant 4 bons payeurs (Good) et 2 mauvais (Bad)~:
\[
\hat{p}_{G} = \frac{4}{6} = 0.6667 \qquad \hat{p}_{B} = \frac{2}{6} = 0.3333
\]

\noindent\textbf{Gini~:} $G = \hat{p}_{G}(1-\hat{p}_{G}) + \hat{p}_{B}(1-\hat{p}_{B}) = 0.6667\times0.3333 + 0.3333\times0.6667 = 0.4444$

\noindent\textbf{Déviance~:} $D = -\bigl(0.6667\log0.6667 + 0.3333\log0.3333\bigr) = 0.6365$

Si la région était pure (6 Good, 0 Bad)~: $G = 0$, $D = 0$.

\medskip
\noindent\textbf{Code Python~:}
\begin{lstlisting}[language=Python]
import numpy as np
p = np.array([4/6, 2/6])
gini = (p * (1 - p)).sum()
dev  = -(p * np.log(p)).sum()
print(f"Gini = {gini:.4f}, Deviance = {dev:.4f}")
\end{lstlisting}

\noindent\textbf{Code R~:}
\begin{lstlisting}[]
p <- c(4/6, 2/6)
gini <- sum(p * (1 - p))
dev  <- -sum(p * log(p))
cat(sprintf("Gini = %.4f, Deviance = %.4f\n", gini, dev))
\end{lstlisting}

\subsection{Évaluation des performances}
On utilise un échantillon test ou la validation croisée pour estimer l'erreur de prédiction (taux d'erreur, AUC, etc.).

\subsection{Propriétés}
\begin{itemize}
  \item Avantages: interprétabilité, gestion des variables mixtes, non-parametric
  \item Inconvénients: variance élevée, instabilité
\end{itemize}

\section{Méta-algorithmes}

\subsection{Introduction}
Les méthodes d'agrégation combinent plusieurs prédictions fournies par différents modèles pour améliorer les performances. Nous présentons deux procédures classiques: le \textbf{bagging} et le \textbf{boosting}.

\subsection{Bagging (Bootstrap Aggregating)}

\subsubsection{Régression}
Le bagging réduit la variance d'un prédicteur instable (comme un arbre). Principe:
\begin{enumerate}
  \item Constituer $B$ échantillons bootstrap (tirage avec remise)
  \item Ajuster un prédicteur sur chaque échantillon
  \item Moyenner les $B$ prédictions: $\hat{f}_{bag}(x) = \frac{1}{B} \sum_{b=1}^{B} \hat{f}_b(x)$
\end{enumerate}

La variance des prédictions diminue quand $B$ augmente:
\[
\mathbb{V}\left[\frac{1}{B}\sum_{b=1}^{B} \hat{f}_b(x)\right] = \frac{1}{B} \mathbb{V}[\hat{f}_b(x)] + \frac{B-1}{B} \text{Cov}[\hat{f}_b(x), \hat{f}_{b'}(x)]
\]

\subsubsection*{Application numérique — Échantillons bootstrap}
Avec $n=5$ observations $\{A,B,C,D,E\}$, trois échantillons bootstrap~:

\begin{center}
\begin{tabular}{c|c}
Itération & Échantillon bootstrap \\
\midrule
1 & $A, A, B, C, E$ \\
2 & $B, C, D, D, E$ \\
3 & $A, C, E, E, E$ \\
\end{tabular}
\end{center}

Chaque échantillon contient environ $1-(1-\frac1n)^n \approx 63\%$ d'observations uniques.
Les $B$ arbres sont ajustés sur ces échantillons, puis leurs prédictions sont moyennées.

\medskip
\noindent\textbf{Code Python~:}
\begin{lstlisting}[language=Python]
from sklearn.utils import resample
X = np.array(['A','B','C','D','E'])
for b in range(3):
    boot = resample(X)
    print(f"Bootstrap {b+1}: {boot}")
\end{lstlisting}

\noindent\textbf{Code R~:}
\begin{lstlisting}[]
x <- c("A", "B", "C", "D", "E")
for (b in 1:3) {
  boot <- sample(x, replace = TRUE)
  cat(sprintf("Bootstrap %d: %s\n", b, paste(boot, collapse = " ")))
}
\end{lstlisting}

\textbf{Erreur OOB (Out-Of-Bag).} Les observations non sélectionnées dans chaque bootstrap servent d'échantillon test:
\[
\widehat{OOB} = \frac{1}{n} \sum_{i=1}^{n} \left( \hat{y}_i^{OOB} - y_i \right)^2
\]

\subsubsection{Classification}
Pour la classification:
\begin{itemize}
  \item Agrégation des probabilités prédites (préférable)
  \item Vote majoritaire des classes prédites
  \item Erreur OOB adaptée au cadre qualitatif
\end{itemize}

\subsubsection{Importance des variables}
L'importance d'une variable $X^j$ est mesurée par la \textbf{Mean Decrease Accuracy}:
\[
VI(X^j) = \frac{1}{B} \sum_{b=1}^{B} \left( \widetilde{OOB}_b^j - OOB_b \right)
\]
où $\widetilde{OOB}_b^j$ est l'erreur OOB après permutation de $X^j$.

\subsubsection*{Application numérique — Importance par permutation}
Reprenons les 6 clients. On compare les prédictions avant et après permutation de l'âge~:

\begin{center}
\begin{tabular}{c|c|c}
$y$ réel & $\hat{y}$ (original) & $\hat{y}_{\text{perm}}$ (âge permuté) \\
\midrule
62 & 65 & 68 \\
75 & 78 & 78 \\
85 & 82 & 82 \\
65 & 68 & 65 \\
90 & 88 & 88 \\
72 & 70 & 72 \\
\end{tabular}
\end{center}

\noindent MSE de base~: $\frac16\bigl[(62-65)^2+(75-78)^2+\cdots\bigr] = \frac{46}{6} = 7.67$ \\
MSE après permutation~: $\frac16\bigl[(62-68)^2+(75-78)^2+\cdots\bigr] = \frac{54}{6} = 9.00$ \\
$VI(\text{Âge}) = 9.00 - 7.67 = 1.33$

\medskip
\noindent\textbf{Code Python~:}
\begin{lstlisting}[language=Python]
from sklearn.metrics import mean_squared_error
y = np.array([62, 75, 85, 65, 90, 72])
y_pred = np.array([65, 78, 82, 68, 88, 70])
y_perm = np.array([68, 78, 82, 65, 88, 72])
vi = mean_squared_error(y, y_perm) - mean_squared_error(y, y_pred)
print(f"Importance Age: {vi:.2f}")
\end{lstlisting}

\noindent\textbf{Code R~:}
\begin{lstlisting}[]
y <- c(62, 75, 85, 65, 90, 72)
y_pred <- c(65, 78, 82, 68, 88, 70)
y_perm <- c(68, 78, 82, 65, 88, 72)
vi <- mean((y - y_perm)^2) - mean((y - y_pred)^2)
cat(sprintf("Importance Age: %.2f\n", vi))
\end{lstlisting}

\subsection{Boosting (AdaBoost)}

Le boosting construit séquentiellement des prédicteurs adaptatifs.

\textbf{Algorithme AdaBoost:}
\begin{enumerate}
  \item Initialiser les poids $p_i^{(0)} = 1/n$
  \item Pour $b = 1$ à $B$:
  \begin{itemize}
    \item Ajuster un classifieur $f_b$ avec les poids $p_i^{(b-1)}$
    \item Calculer l'erreur pondérée $e_b = \sum_{i: f_b(x_i) \neq y_i} p_i^{(b-1)}$
    \item Calculer $\alpha_b = \log\left(\frac{1-e_b}{e_b}\right)$
    \item Mettre à jour les poids: $p_i^{(b)} = \exp(\alpha_b) \cdot p_i^{(b-1)}$ pour les mal classés
    \item Normaliser les poids
  \end{itemize}
  \item Classifieur final: $\hat{f}(x) = \text{signe}\left( \sum_{b=1}^{B} \alpha_b \hat{f}_b(x) \right)$
\end{enumerate}

\subsubsection*{Application numérique — AdaBoost pas à pas}
Quatre clients avec une règle simple~: score $<70 \Rightarrow +1$ (Good)~:

\begin{center}
\begin{tabular}{c|c|c|c}
$i$ & Score & $y_i$ & $f_1(x_i)=\text{signe}(70-\text{score})$ \\ \midrule
1 & 62 & $+1$ & $+1$~$\checkmark$ \\
2 & 85 & $-1$ & $-1$~$\checkmark$ \\
3 & 72 & $+1$ & $-1$~$\times$ \\
4 & 65 & $-1$ & $+1$~$\times$ \\
\end{tabular}
\end{center}

\noindent\textbf{Itération~1~:}
\begin{itemize}
\item Erreur pondérée~: $e_1 = w_3 + w_4 = 0.25 + 0.25 = 0.50$
\item Poids du classifieur~: $\alpha_1 = \frac12\log\frac{1-0.5}{0.5} = 0$
\item Tous les poids restent à 0.25, l'algorithme passe à l'itération suivante.
\end{itemize}

\noindent\textbf{Itération~2~:} Utilisons un stump différent~: $f_2(x)=\text{signe}(80-\text{score})$
\begin{itemize}
\item Mal classé~: client~2 (score 85, prédit $-1$) et client~3 (score 72, prédit $-1$)
\item $e_2 = 0.25 + 0.25 = 0.50$ → même situation.
\end{itemize}

Ajoutons un 5\ieme{} client atypique (score 78, $y=-1$, poids initial 0.20) pour que les poids $e \neq 0.5$~:

\begin{center}
\begin{tabular}{c|c|c|c}
$i$ & Score & $y_i$ & $f_1(x)=\text{signe}(70-\text{score})$ \\ \midrule
1 & 62 & $+1$ & $+1$~$\checkmark$ \\
2 & 85 & $-1$ & $-1$~$\checkmark$ \\
3 & 72 & $+1$ & $-1$~$\times$ \\
4 & 65 & $-1$ & $+1$~$\times$ \\
5 & 78 & $-1$ & $-1$~\checkmark \\
\end{tabular}
\end{center}

\noindent\textbf{Itération~1~:}
\begin{itemize}
\item $e_1 = w_3 + w_4 = 0.20 + 0.20 = 0.40$
\item $\alpha_1 = \frac12\log\frac{1-0.40}{0.40} = \frac12\log(1.50) = 0.203$
\item Mise à jour~: $w_3 = w_4 = 0.20\times e^{0.203} = 0.245$ ; $w_1 = w_2 = w_5 = 0.20\times e^{-0.203} = 0.163$
\item Normalisation~: diviser par la somme $2\times0.245 + 3\times0.163 = 0.979$
\item $w = [0.167, 0.167, 0.250, 0.250, 0.167]$
\end{itemize}

\noindent\textbf{Itération~2~:} $f_2(x)=\text{signe}(75-\text{score})$ classe correctement le client~3.
\begin{itemize}
\item $e_2 = w_4$ (client 4 toujours mal classé si score $< 75$) $= 0.250$
\item $\alpha_2 = \frac12\log\frac{1-0.25}{0.25} = 0.549$
\end{itemize}

Classifieur final~: $\hat{f}(x) = \text{signe}\bigl(0.203\,f_1(x) + 0.549\,f_2(x)\bigr)$.

\medskip
\noindent\textbf{Code Python~:}
\begin{lstlisting}[language=Python]
import numpy as np
score = np.array([62, 85, 72, 65, 78])
y     = np.array([1, -1, 1, -1, -1])
n = len(score); w = np.ones(n) / n
for b in range(2):
    pred = np.where(score < 70, 1, -1)
    if b == 1: pred = np.where(score < 75, 1, -1)
    e = w[pred != y].sum()
    alpha = 0.5 * np.log((1 - e) / max(e, 1e-15))
    w[pred != y] *= np.exp(alpha)
    w[pred == y] *= np.exp(-alpha)
    w /= w.sum()
    print(f"B={b+1}: e={e:.4f}, alpha={alpha:.4f}, w={np.round(w,4)}")
\end{lstlisting}

\noindent\textbf{Code R~:}
\begin{lstlisting}[]
score <- c(62, 85, 72, 65, 78)
y     <- c(1, -1, 1, -1, -1)
n <- length(score); w <- rep(1/n, n)
for (b in 1:2) {
  if (b == 1) pred <- ifelse(score < 70, 1, -1)
  if (b == 2) pred <- ifelse(score < 75, 1, -1)
  e <- sum(w[pred != y])
  alpha <- 0.5 * log((1 - e) / max(e, 1e-15))
  w[pred != y] <- w[pred != y] * exp(alpha)
  w[pred == y] <- w[pred == y] * exp(-alpha)
  w <- w / sum(w)
  cat(sprintf("B=%d: e=%.4f, alpha=%.4f\n", b, e, alpha))
  cat("  w:", round(w, 4), "\n")
}
\end{lstlisting}

